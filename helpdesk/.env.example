# Copy this to .env and fill in your values

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail — for sending fallback emails TO you, and auto-replying FROM your studio inbox
GMAIL_ADDRESS=yourstudio@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here   # 16-char App Password (not your login password)

# The studio owner's email — fallback emails get sent here
STUDIO_OWNER_EMAIL=owner@dualitypole.com

# Instagram / Meta (for DM webhook)
INSTAGRAM_VERIFY_TOKEN=pick_any_random_string_here
INSTAGRAM_PAGE_ACCESS_TOKEN=your_meta_page_access_token_here
INSTAGRAM_PAGE_ID=your_instagram_page_id_here

# General
PORT=8000
